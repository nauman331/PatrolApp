# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.1'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Patrolapp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Stale .xcode.env.local caches an absolute Node path and causes xcodebuild
    # error 65 with misleading "export CLANG_WARN_*" lines in the CLI output.
    xcode_env_local = File.join(Pod::Config.instance.installation_root, '.xcode.env.local')
    if File.exist?(xcode_env_local)
      Pod::UI.puts 'Removing stale ios/.xcode.env.local (outdated Node path)'.yellow
      File.delete(xcode_env_local)
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'

        # Xcode 14+ on Apple Silicon: skip signing for pod resource bundles
        if target.respond_to?(:product_type) &&
           target.product_type == 'com.apple.product-type.bundle'
          config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        end
      end
    end

    # Apple Silicon (M1/M2/M3): keep simulator on arm64 — do not exclude arm64
    installer.pods_project.build_configurations.each do |config|
      config.build_settings.delete('EXCLUDED_ARCHS[sdk=iphonesimulator*]')
    end
  end
end
