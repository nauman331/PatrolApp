# Used by Xcode build scripts to locate Node.js.
# Do not hardcode absolute Node paths in .xcode.env.local — that causes
# xcodebuild error 65 when Node is upgraded or moved.

unset NODE_BINARY

# nvm (direct install or Homebrew)
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh" --no-use
  nvm use 2>/dev/null || nvm use default 2>/dev/null || true
elif command -v brew >/dev/null 2>&1; then
  NVM_SCRIPT="$(brew --prefix nvm 2>/dev/null)/nvm.sh"
  if [ -s "$NVM_SCRIPT" ]; then
    . "$NVM_SCRIPT" --no-use
    nvm use 2>/dev/null || nvm use default 2>/dev/null || true
  fi
fi

# fnm
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env)"
fi

export NODE_BINARY="${NODE_BINARY:-$(command -v node)}"
