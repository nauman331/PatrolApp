# Production API
API_BASE_URL=https://apis-nfc.arrowbyte.com.au
INCIDENT_ASSETS_BASE_URL=https://apis-nfc.arrowbyte.com.au/incident

# Local Laravel on PC — Postman uses localhost, the phone cannot.
# 1) Run: php artisan serve --host=0.0.0.0 --port=8000
# 2) Set your PC LAN IP below (ipconfig → IPv4)
# 3) Uncomment local URLs and DEV_MACHINE_IP, restart Metro with --reset-cache
#
# DEV_MACHINE_IP=192.168.18.224
# API_BASE_URL=http://127.0.0.1:8000
# INCIDENT_ASSETS_BASE_URL=http://127.0.0.1:8000/incident
