# Production API (works on iPhone without extra config)
API_BASE_URL=https://apis-nfc.arrowbyte.com.au
INCIDENT_ASSETS_BASE_URL=https://apis-nfc.arrowbyte.com.au/incident

# ── iPhone XS Max + M1 Mac (local Laravel API) ─────────────────────────────
# Phone and Mac must be on the SAME Wi‑Fi.
# 1) On Mac Terminal: ipconfig getifaddr en0   → copy the IP (e.g. 192.168.1.42)
# 2) Run Laravel: php artisan serve --host=0.0.0.0 --port=8000
# 3) Uncomment and set your Mac IP below, then restart Metro: npm start -- --reset-cache
#
# DEV_MACHINE_IP=192.168.1.42
# API_BASE_URL=http://192.168.1.42:8000
# INCIDENT_ASSETS_BASE_URL=http://192.168.1.42:8000/incident
